{
    "version": "2.0.0",
    "inputs": [
        {
            "id": "buildType",
            "description": "Build Type",
            "type": "pickString",
            "options": [
                "Debug",
                "Release"
            ],
            "default": "Release"
        },
        {
            "id": "conanBuildPolicy",
            "description": "Conan Build Policy",
            "type": "pickString",
            "options": [
                "missing",
                "all"
            ],
            "default": "missing"
        },
        {
            "id": "enableCoverage",
            "description": "Enable Code Coverage",
            "type": "pickString",
            "options": [
                "False",
                "True"
            ],
            "default": "False"
        },
        {
            "id": "targetPlatform",
            "description": "Target Platform",
            "type": "pickString",
            "options": [
                "Native",
                "Emscripten (WebAssembly)"
            ],
            "default": "Native"
        }
    ],
    "tasks": [
        {
            "label": "Conan Build",
            "type": "shell",
            "command": "conan build . --build=missing -s build_type=${input:buildType} -o \"&:enable_coverage=${input:enableCoverage}\"",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Conan Install",
            "type": "shell",
            "command": "conan",
            "args": [
                "install",
                ".",
                "--build=missing",
                "-s",
                "build_type=${input:buildType}",
                "-o",
                "\"&:enable_coverage=${input:enableCoverage}\""
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "CMake Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${command:cmake.buildDirectory}"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Generate Coverage Report",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "coverage-all"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Open Coverage Report",
            "type": "shell",
            "command": "open",
            "args": [
                "${workspaceFolder}/build/Debug/coverage/msd-sim/index.html"
            ],
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Create Conan Dependencies",
            "type": "shell",
            "command": [
                "echo '=== Building Conan Dependencies ===';",
                "conan create conan/spirv_cross --build=${input:conanBuildPolicy} -s build_type=Release;",
                // "# conan create conan/dxc --build=${input:conanBuildPolicy} -s build_type=Release;",
                "conan create conan/sdl_shadercross --build=${input:conanBuildPolicy} -s build_type=Release;",
                "conan create conan/sdl --build=${input:conanBuildPolicy} -s build_type=Debug;",
                "conan create conan/sdl --build=${input:conanBuildPolicy} -s build_type=Release;",
                "conan create conan/sdl_image --build=${input:conanBuildPolicy} -s build_type=Release;",
                "conan create conan/sdl_image --build=${input:conanBuildPolicy} -s build_type=Debug;",
                "conan create conan/sdl_mixer --build=${input:conanBuildPolicy} -s build_type=Release;",
                "conan create conan/sdl_mixer --build=${input:conanBuildPolicy} -s build_type=Debug;",
                "conan create conan/sdl_ttf --build=${input:conanBuildPolicy} -s build_type=Release;",
                "conan create conan/sdl_ttf --build=${input:conanBuildPolicy} -s build_type=Debug;",
                "conan create conan/qhull --build=${input:conanBuildPolicy} -s build_type=Release;",
                "conan create conan/qhull --build=${input:conanBuildPolicy} -s build_type=Debug;",
                "conan create conan/sqlite3 --build=${input:conanBuildPolicy} -s build_type=Release;",
                "conan create conan/sqlite3 --build=${input:conanBuildPolicy} -s build_type=Debug;",
                "conan create conan/cpp_sqlite --build=${input:conanBuildPolicy} -s build_type=Release;",
                "conan create conan/cpp_sqlite --build=${input:conanBuildPolicy} -s build_type=Debug;",
                "echo '=== Building Emscripten SDK ===';",
                "conan create conan/emsdk --build=${input:conanBuildPolicy};",
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Install DXC",
            "type": "shell",
            "command": [
                "conan create conan/dxc --build=${input:conanBuildPolicy} -s build_type=Release;",
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "DXC_INSTALL_DIR": "${workspaceFolder}/installs/dxc"
                }
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Install Shadercross",
            "type": "shell",
            "command": [
                "conan create conan/sdl_shadercross --build=${input:conanBuildPolicy} -s build_type=Release;",
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "SHADERCROSS_INSTALL_DIR": "${workspaceFolder}/installs/sdl_shadercross"
                }
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Compile Shaders",
            "type": "shell",
            "command": "bash",
            "args": [
                "msd/msd-gui/src/Content/Shaders/Source/compile.sh"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "${workspaceFolder}/installs/sdl_shadercross/bin:${workspaceFolder}/installs/dxc/bin:${env:PATH}"
                }
            },
            "dependsOn": [
                "Install DXC",
                "Install Shadercross"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Create Conan Dependencies (Emscripten)",
            "type": "shell",
            "command": [
                "echo '=== Building Emscripten Conan Dependencies ===';",
                "conan create conan/emsdk --build=${input:conanBuildPolicy};",
                "conan create conan/sqlite3 --profile:host profiles/emscripten.profile --build=${input:conanBuildPolicy};",
                "conan create conan/cpp_sqlite --profile:host profiles/emscripten.profile --build=${input:conanBuildPolicy};",
                "conan create conan/qhull --profile:host profiles/emscripten.profile --build=${input:conanBuildPolicy};",
                "echo '=== Emscripten Dependencies Complete ===';"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Conan Install (Emscripten)",
            "type": "shell",
            "command": "conan",
            "args": [
                "install",
                ".",
                "--profile:host",
                "profiles/emscripten.profile",
                "--build=missing",
                "-of",
                "build/Emscripten"
            ],
            "group": "build",
            "dependsOn": [
                "Create Conan Dependencies (Emscripten)"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Build Emscripten (WebAssembly)",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "cmake --preset emscripten-release && cmake --build --preset emscripten-release"
            ],
            "group": "build",
            "dependsOn": [
                "Conan Install (Emscripten)"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Serve Emscripten Build",
            "type": "shell",
            "command": "python3",
            "args": [
                "-m",
                "http.server",
                "8080"
            ],
            "options": {
                "cwd": "${workspaceFolder}/build/Emscripten"
            },
            "isBackground": true,
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated"
            },
            "problemMatcher": []
        }
    ]
}